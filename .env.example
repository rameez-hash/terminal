# Neon (Vercel integration auto-adds these)
DATABASE_URL="postgresql://...-pooler.../neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://.../neondb?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://...-pooler.../neondb?connect_timeout=15&sslmode=require"

# Required for auth
NEXTAUTH_URL="https://terminal-xfal.vercel.app"
NEXTAUTH_SECRET="generate-a-long-random-secret"
AUTH_SECRET="same-as-nextauth-secret"

DEMO_MODE="false"

# Stripe (optional)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal (optional)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"
