# Neon (Vercel integration auto-adds these)
DATABASE_URL="postgresql://...-pooler.../neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://.../neondb?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://...-pooler.../neondb?connect_timeout=15&sslmode=require"

# Auth
NEXTAUTH_URL="https://terminal.bmdhouse.com"
NEXTAUTH_SECRET="your-long-random-secret"
AUTH_SECRET="same-as-nextauth-secret"

# Set false when Stripe/PayPal keys are added
DEMO_MODE="false"

# ─── Stripe ───────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhooks: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://terminal.bmdhouse.com/api/webhooks/stripe
# Events: checkout.session.completed, payment_intent.succeeded
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── PayPal ───────────────────────────────────────────────
# Dashboard: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID="your-client-id"
PAYPAL_CLIENT_SECRET="your-client-secret"
PAYPAL_MODE="live"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="same-as-paypal-client-id"
# Webhooks: https://developer.paypal.com/dashboard/applications
# Endpoint URL: https://terminal.bmdhouse.com/api/webhooks/paypal
PAYPAL_WEBHOOK_ID="your-webhook-id"
